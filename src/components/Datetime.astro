---
import IconCalendar from "@phosphor-icons/core/assets/regular/calendar-blank.svg";
import { SITE } from "@/config";
import Icon from "./Icon.astro";

type Props = {
	class?: string;
	size?: "sm" | "lg";
	pubDatetime: string | Date;
	timezone?: string;
	modDatetime?: string | Date | null;
};

const {
	pubDatetime,
	modDatetime,
	size = "sm",
	class: className = "",
	timezone: postTimezone,
} = Astro.props;

/* ========== Formatted Datetime ========== */
const isModified = modDatetime && modDatetime > pubDatetime;

const datetime = new Date(isModified ? modDatetime : pubDatetime);

// e.g., '22 Mar, 2025' in the post's (or site's) IANA timezone — the same
// "D MMM, YYYY" rendering this component produced with dayjs.
const parts = new Intl.DateTimeFormat("en-US", {
	timeZone: postTimezone || SITE.timezone,
	day: "numeric",
	month: "short",
	year: "numeric",
}).formatToParts(datetime);
const part = (type: Intl.DateTimeFormatPartTypes) =>
	parts.find((p) => p.type === type)?.value ?? "";
const date = `${part("day")} ${part("month")}, ${part("year")}`;
---

<div class:list={["flex items-center gap-x-2 opacity-80", className]}>
  <Icon
    icon={IconCalendar}
    class={`inline-block size-6 min-w-5.5 ${size === "sm" ? "scale-90" : ""}`}
  />
  {
    isModified && (
      <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
        Updated:
      </span>
    )
  }
  <time
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
    datetime={datetime.toISOString()}>{date}</time
  >
</div>
