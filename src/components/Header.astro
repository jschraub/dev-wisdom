---
import IconArchive from "@phosphor-icons/core/assets/regular/archive.svg";
import IconMenuDeep from "@phosphor-icons/core/assets/regular/list.svg";
import IconSearch from "@phosphor-icons/core/assets/regular/magnifying-glass.svg";
import IconMonitor from "@phosphor-icons/core/assets/regular/monitor.svg";
import IconMoon from "@phosphor-icons/core/assets/regular/moon.svg";
import IconSunHigh from "@phosphor-icons/core/assets/regular/sun.svg";
import IconX from "@phosphor-icons/core/assets/regular/x.svg";
import { SITE } from "@/config";
import Icon from "./Icon.astro";
import LinkButton from "./LinkButton.astro";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
	pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
	const currentPathArray = currentPath.split("/").filter((p) => p.trim());
	const pathArray = path.split("/").filter((p) => p.trim());

	return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 rounded-md border border-border bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4 motion-reduce:transition-none"
>
  Skip to content
</a>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "relative w-full bg-background",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href="/"
      class="absolute py-1 text-xl leading-8 font-semibold tracking-[-0.01em] whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}{" "}
      {/* The brand mark's gold check-as-period — same gesture as the favicon
          and OG brand row (ADR 0003 amendment, issue #11). */}
      <svg
        viewBox="0 0 26 22"
        class="inline-block size-[0.5em] text-gold"
        aria-hidden="true"
        fill="none"
      >
        <path
          d="M2 12 L9 19 L24 3"
          stroke="currentColor"
          stroke-width="5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
    >
      <button
        id="menu-btn"
        class="self-end rounded-md p-2 hover:text-accent sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <Icon icon={IconX} id="close-icon" class="hidden" />
        <Icon icon={IconMenuDeep} id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-44 grid-cols-2 place-content-center gap-2",
          "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
          "hidden",
          "sm:mt-0 sm:flex sm:w-auto sm:gap-x-5 sm:gap-y-0",
        ]}
      >
        <li class="col-span-2">
          <a href="/posts" class:list={{ "active-nav": isActive("/posts") }}>
            Posts
          </a>
        </li>
        <li class="col-span-2">
          <a href="/tags" class:list={{ "active-nav": isActive("/tags") }}>
            Tags
          </a>
        </li>
        <li class="col-span-2">
          <a href="/about" class:list={{ "active-nav": isActive("/about") }}>
            About
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href="/archives"
                class:list={[
                  "flex justify-center rounded-md p-3 sm:p-1",
                  {
                    "active-nav text-accent": isActive("/archives"),
                  },
                ]}
                title="Archives"
                aria-label="archives"
              >
                <Icon icon={IconArchive} class="hidden sm:inline-block" />
                <span class="sm:sr-only">Archives</span>
              </LinkButton>
            </li>
          )
        }
        <li class="col-span-1 flex items-center justify-center">
          {/* Progressively enhanced: SearchOverlay's delegated click handler
              opens the ⌘K dialog; without JS this stays a link to /search. */}
          <LinkButton
            id="search-btn"
            href="/search"
            class:list={[
              "flex rounded-md p-3 sm:p-1",
              { "text-accent": isActive("/search") },
            ]}
            title="Search (⌘K)"
            aria-label="Search"
          >
            <Icon icon={IconSearch} />
            <span class="sr-only">Search</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="col-span-1 flex items-center justify-center">
              {/* Cycles light → system → dark (src/scripts/theme.ts).
                  Icon shown = current *preference*, keyed off the
                  data-theme-preference attribute on <html>. Monitor is the
                  base state so it also renders without JS. aria-live lets
                  the aria-label mutation announce each change. */}
              <button
                id="theme-btn"
                class="relative size-12 rounded-md p-4 hover:text-accent sm:size-8"
                title="Theme: system"
                aria-label="Theme: system"
                aria-live="polite"
              >
                <Icon
                  icon={IconSunHigh}
                  class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all motion-reduce:transition-none [[data-theme-preference=light]_&]:scale-100 [[data-theme-preference=light]_&]:rotate-0"
                />
                <Icon
                  icon={IconMonitor}
                  class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all motion-reduce:transition-none [[data-theme-preference=dark]_&]:scale-0 [[data-theme-preference=dark]_&]:-rotate-90 [[data-theme-preference=light]_&]:scale-0 [[data-theme-preference=light]_&]:rotate-90"
                />
                <Icon
                  icon={IconMoon}
                  class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 -rotate-90 transition-all motion-reduce:transition-none [[data-theme-preference=dark]_&]:scale-100 [[data-theme-preference=dark]_&]:rotate-0"
                />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
