---
import IconHash from "@phosphor-icons/core/assets/regular/hash.svg";
import Icon from "./Icon.astro";

type Props = {
	tag: string;
	tagName: string;
	size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "inline-flex items-center gap-1 rounded-full font-mono",
      "border border-accent/25 bg-accent/10 text-accent",
      "transition-colors hover:border-accent/50 hover:bg-accent/15 motion-reduce:transition-none",
      size === "sm" ? "px-2.5 py-0.5 text-xs" : "px-3 py-1 text-sm",
    ]}
  >
    <Icon icon={IconHash} class="size-4 opacity-80" />
    {tagName}
  </a>
</li>
