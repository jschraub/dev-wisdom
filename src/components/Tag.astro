---
import IconHash from "@phosphor-icons/core/assets/regular/hash.svg";
import Icon from "./Icon.astro";

type Props = {
	tag: string;
	tagName: string;
	size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "flex items-center gap-0.5",
      "border-b-2 border-dashed border-foreground",
      "hover:-mt-0.5 hover:border-accent hover:text-accent",
      "focus-visible:border-none focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <Icon
      icon={IconHash}
      class={`opacity-80 ${size === "lg" ? "size-5" : "size-4"}`}
    />
    {tagName}
  </a>
</li>
